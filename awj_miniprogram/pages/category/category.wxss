.category-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.search-bar {
  position: relative;
  background: #ffffff;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.search-input {
  width: 85%;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 30rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #ff6b35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.category-sidebar {
  width: 180rpx;
  background: #f5f5f5;
  height: calc(100vh - 170rpx);
}

.sidebar-item {
  padding: 30rpx 15rpx;
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  border-left: 6rpx solid transparent;
}

.sidebar-item.active {
  background: #ffffff;
  color: #ff6b35;
  border-left-color: #ff6b35;
  font-weight: 600;
}

.content-area {
  flex: 1;
  padding: 20rpx;
  height: calc(100vh - 170rpx);
}

.product-list, .service-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card, .service-card {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.product-image, .service-image {
  width: 100%;
  height: 200rpx;
}

.product-name, .service-name {
  padding: 15rpx;
  font-size: 26rpx;
  color: #333333;
}

.product-price, .service-price {
  padding: 0 15rpx;
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: 600;
}

.product-price::before, .service-price::before {
  content: '¥';
  font-size: 22rpx;
}

.product-sales, .service-duration {
  padding: 10rpx 15rpx 15rpx;
  font-size: 22rpx;
  color: #999999;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}
