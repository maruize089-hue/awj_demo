<view class="category-container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品或服务" bindinput="onSearchInput" bindconfirm="onSearch" value="{{keyword}}" />
    <text class="search-icon" bindtap="onSearch">🔍</text>
  </view>
  
  <view class="tabs">
    <view class="tab-item {{activeTab === 'PRODUCT' ? 'active' : ''}}" bindtap="switchTab" data-tab="PRODUCT">
      商品
    </view>
    <view class="tab-item {{activeTab === 'SERVICE' ? 'active' : ''}}" bindtap="switchTab" data-tab="SERVICE">
      服务
    </view>
  </view>
  
  <scroll-view class="category-sidebar" scroll-y>
    <view class="sidebar-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{currentCategories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
      {{item.name}}
    </view>
  </scroll-view>
  
  <scroll-view class="content-area" scroll-y>
    <view class="product-list" wx:if="{{activeTab === 'PRODUCT'}}">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="PRODUCT">
        <image class="product-image" src="{{item.image}}" mode="aspectFill" />
        <text class="product-name ellipsis-2">{{item.name}}</text>
        <text class="product-price">{{item.price}}</text>
        <text class="product-sales">销量 {{item.sales}}</text>
      </view>
    </view>
    
    <view class="service-list" wx:else>
      <view class="service-card" wx:for="{{services}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="SERVICE">
        <image class="service-image" src="{{item.image}}" mode="aspectFill" />
        <text class="service-name ellipsis-2">{{item.name}}</text>
        <text class="service-price">{{item.price}}</text>
        <text class="service-duration">{{item.duration}}分钟</text>
      </view>
    </view>
    
    <view class="empty-tip" wx:if="{{(activeTab === 'PRODUCT' && products.length === 0) || (activeTab === 'SERVICE' && services.length === 0)}}">
      <text>暂无数据</text>
    </view>
  </scroll-view>
</view>
