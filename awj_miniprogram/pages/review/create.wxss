.review-create-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.order-info {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 15rpx;
  display: block;
}

.order-items {
  display: flex;
}

.order-item {
  width: 120rpx;
  margin-right: 15rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.item-name {
  font-size: 22rpx;
  color: #666666;
  display: block;
  margin-top: 5rpx;
}

.rating-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.rating-label {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.rating-stars {
  display: flex;
}

.star-icon {
  font-size: 56rpx;
  color: #e0e0e0;
  margin-right: 20rpx;
}

.star-icon.active {
  color: #ffd700;
}

.content-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.content-label {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 15rpx;
  display: block;
}

.content-textarea {
  width: 100%;
  height: 300rpx;
  font-size: 30rpx;
  color: #333333;
}

.submit-btn {
  position: fixed;
  bottom: 100rpx;
  left: 20rpx;
  right: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}
