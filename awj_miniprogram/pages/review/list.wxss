.review-list-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.review-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.review-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.review-content {
  flex: 1;
}

.review-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.review-user {
  font-size: 28rpx;
  color: #333333;
}

.review-time {
  font-size: 24rpx;
  color: #999999;
}

.review-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  margin-top: 15rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.review-rating {
  margin-top: 15rpx;
}

.star-icon {
  font-size: 32rpx;
  color: #ffd700;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}
