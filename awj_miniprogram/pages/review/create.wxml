<view class="review-create-container">
  <view class="order-info" wx:if="{{order}}">
    <text class="order-no">订单号：{{order.orderNo}}</text>
    <view class="order-items">
      <view class="order-item" wx:for="{{order.items}}" wx:key="id">
        <image class="item-image" src="{{item.image}}" mode="aspectFill" />
        <text class="item-name ellipsis-2">{{item.name}}</text>
      </view>
    </view>
  </view>
  
  <view class="rating-section">
    <text class="rating-label">评分</text>
    <view class="rating-stars">
      <text class="star-icon {{index < rating ? 'active' : ''}}" wx:for="5" wx:key="index" bindtap="setRating" data-rating="{{index + 1}}">★</text>
    </view>
  </view>
  
  <view class="content-section">
    <text class="content-label">评价内容</text>
    <textarea class="content-textarea" placeholder="请输入您的评价" bindinput="onContentInput" value="{{content}}" />
  </view>
  
  <button class="submit-btn" bindtap="submitReview" loading="{{loading}}">提交评价</button>
</view>
