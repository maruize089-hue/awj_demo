.coupon-list-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #ff6b35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.coupon-list {
  padding: 20rpx;
}

.coupon-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.coupon-left {
  width: 180rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.coupon-amount {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 600;
}

.coupon-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.coupon-right {
  flex: 1;
  padding: 30rpx;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.coupon-condition {
  font-size: 26rpx;
  color: #ff6b35;
  display: block;
  margin-bottom: 10rpx;
}

.coupon-expire {
  font-size: 24rpx;
  color: #999999;
}

.coupon-status {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.3);
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}
