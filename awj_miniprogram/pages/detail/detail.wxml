<scroll-view class="detail-container" scroll-y>
  <image class="detail-image" src="{{item.image}}" mode="aspectFill" />
  
  <view class="detail-header">
    <text class="detail-name">{{item.name}}</text>
    <text class="detail-price">{{item.price}}</text>
    <text class="detail-original-price" wx:if="{{item.originalPrice}}">{{item.originalPrice}}</text>
  </view>
  
  <view class="detail-info">
    <view class="info-row">
      <text class="info-label">销量</text>
      <text class="info-value">{{item.sales || 0}}份</text>
    </view>
    <view class="info-row" wx:if="{{item.duration}}">
      <text class="info-label">服务时长</text>
      <text class="info-value">{{item.duration}}分钟</text>
    </view>
    <view class="info-row" wx:if="{{item.categoryName}}">
      <text class="info-label">分类</text>
      <text class="info-value">{{item.categoryName}}</text>
    </view>
    <view class="info-row" wx:if="{{item.description}}">
      <text class="info-label">描述</text>
      <text class="info-value">{{item.description}}</text>
    </view>
  </view>
  
  <view class="detail-content">
    <text class="content-title">商品详情</text>
    <view class="content-body">
      <text>{{item.detail || '暂无详细描述'}}</text>
    </view>
  </view>
  
  <view class="detail-spec" wx:if="{{specs && specs.length > 0}}">
    <text class="spec-title">规格选择</text>
    <view class="spec-list">
      <view class="spec-item {{selectedSpec === spec ? 'selected' : ''}}" wx:for="{{specs}}" wx:key="id" bindtap="selectSpec" data-spec="{{spec}}">
        {{spec.name}} - {{spec.price}}
      </view>
    </view>
  </view>
  
  <view class="review-section">
    <view class="review-header">
      <text class="review-title">用户评价</text>
      <text class="review-count">共{{reviewCount}}条</text>
    </view>
    <view class="review-list">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id">
        <image class="review-avatar" src="{{review.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="review-content">
          <view class="review-header">
            <text class="review-user">{{review.userName}}</text>
            <text class="review-time">{{review.createTime}}</text>
          </view>
          <text class="review-text">{{review.content}}</text>
        </view>
      </view>
      <view class="no-reviews" wx:if="{{reviews.length === 0}}">
        <text>暂无评价</text>
      </view>
    </view>
  </view>
</scroll-view>

<view class="detail-footer">
  <view class="footer-left">
    <view class="footer-item" bindtap="toggleFavorite">
      <text class="footer-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
      <text class="footer-text">收藏</text>
    </view>
    <view class="footer-item" bindtap="goToCart">
      <text class="footer-icon">🛒</text>
      <text class="footer-text">购物车</text>
    </view>
  </view>
  <view class="footer-right">
    <button class="btn-add-cart" bindtap="addToCart">加入购物车</button>
    <button class="btn-buy" bindtap="buyNow">立即购买</button>
  </view>
</view>
