.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.detail-image {
  width: 100%;
  height: 600rpx;
}

.detail-header {
  background: #ffffff;
  padding: 20rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 15rpx;
}

.detail-price {
  font-size: 44rpx;
  color: #ff6b35;
  font-weight: 600;
}

.detail-price::before {
  content: '¥';
  font-size: 32rpx;
}

.detail-original-price {
  font-size: 28rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 20rpx;
}

.detail-original-price::before {
  content: '¥';
}

.detail-info {
  background: #ffffff;
  margin-top: 10rpx;
  padding: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 15rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.detail-content {
  background: #ffffff;
  margin-top: 10rpx;
  padding: 20rpx;
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.content-body {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.detail-spec {
  background: #ffffff;
  margin-top: 10rpx;
  padding: 20rpx;
}

.spec-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  padding: 15rpx 25rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
}

.spec-item.selected {
  background: #ffe8df;
  color: #ff6b35;
  border: 2rpx solid #ff6b35;
}

.review-section {
  background: #ffffff;
  margin-top: 10rpx;
  padding: 20rpx;
  margin-bottom: 120rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.review-count {
  font-size: 26rpx;
  color: #999999;
}

.review-item {
  display: flex;
  margin-bottom: 20rpx;
}

.review-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.review-content {
  flex: 1;
}

.review-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.review-user {
  font-size: 28rpx;
  color: #333333;
}

.review-time {
  font-size: 24rpx;
  color: #999999;
}

.review-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.no-reviews {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.footer-left {
  display: flex;
}

.footer-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.footer-icon {
  font-size: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: 5rpx;
}

.footer-right {
  display: flex;
}

.btn-add-cart {
  width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #ffb385;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-right: 15rpx;
}

.btn-buy {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
