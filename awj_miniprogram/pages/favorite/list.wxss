.favorite-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.favorite-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.favorite-item {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.favorite-image {
  width: 100%;
  height: 280rpx;
}

.favorite-info {
  padding: 20rpx;
}

.favorite-name {
  font-size: 28rpx;
  color: #333333;
}

.favorite-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: 600;
  margin-top: 10rpx;
  display: block;
}

.favorite-price::before {
  content: '¥';
  font-size: 24rpx;
}

.favorite-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 10rpx 20rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  width: 100%;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
