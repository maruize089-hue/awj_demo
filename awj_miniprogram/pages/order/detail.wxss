.order-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.status-section {
  background: #ffffff;
  padding: 40rpx;
  text-align: center;
}

.status-text {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 15rpx;
}

.order-no, .create-time {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.address-section {
  display: flex;
  background: #ffffff;
  padding: 30rpx;
  margin-top: 10rpx;
}

.address-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
}

.address-detail {
  font-size: 28rpx;
  color: #666666;
}

.service-time-section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 10rpx;
}

.time-label {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.time-value {
  font-size: 30rpx;
  color: #333333;
}

.item-section {
  background: #ffffff;
  padding: 20rpx;
  margin-top: 10rpx;
}

.item-card {
  display: flex;
  margin-bottom: 20rpx;
}

.item-card:last-child {
  margin-bottom: 0;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
}

.item-spec {
  font-size: 24rpx;
  color: #999999;
  margin: 10rpx 0;
  display: block;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.item-price {
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: 600;
}

.item-price::before {
  content: '¥';
  font-size: 22rpx;
}

.item-quantity {
  font-size: 26rpx;
  color: #999999;
}

.remark-section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 10rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.remark-value {
  font-size: 30rpx;
  color: #333333;
}

.summary-section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 10rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-label {
  font-size: 28rpx;
  color: #666666;
}

.summary-value {
  font-size: 28rpx;
  color: #333333;
}

.summary-value.discount {
  color: #ff6b35;
}

.summary-row.total {
  padding-top: 15rpx;
  border-top: 2rpx solid #f5f5f5;
}

.summary-total {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: 600;
}

.summary-total::before {
  content: '¥';
  font-size: 26rpx;
}

.pay-info {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 10rpx;
}

.pay-label {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.order-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.action-btn {
  width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.action-btn.primary {
  background: #ff6b35;
  color: #ffffff;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666666;
}
