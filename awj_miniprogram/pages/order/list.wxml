<view class="order-list-container">
  <view class="tabs">
    <view class="tab-item {{activeTab === 'ALL' ? 'active' : ''}}" bindtap="switchTab" data-tab="ALL">
      全部
    </view>
    <view class="tab-item {{activeTab === 'PENDING' ? 'active' : ''}}" bindtap="switchTab" data-tab="PENDING">
      待支付
    </view>
    <view class="tab-item {{activeTab === 'PAID' ? 'active' : ''}}" bindtap="switchTab" data-tab="PAID">
      待服务
    </view>
    <view class="tab-item {{activeTab === 'COMPLETED' ? 'active' : ''}}" bindtap="switchTab" data-tab="COMPLETED">
      已完成
    </view>
    <view class="tab-item {{activeTab === 'REFUNDED' ? 'active' : ''}}" bindtap="switchTab" data-tab="REFUNDED">
      已退款
    </view>
  </view>
  
  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status" style="color: {{getStatusColor(item.status)}}">{{getStatusText(item.status)}}</text>
      </view>
      
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="subItem">
          <image class="item-image" src="{{subItem.image}}" mode="aspectFill" />
          <text class="item-name ellipsis-2">{{subItem.name}}</text>
        </view>
      </view>
      
      <view class="order-footer">
        <text class="order-total">共{{item.itemCount}}件 实付：<text class="total-price">{{item.totalAmount}}</text></text>
        <view class="order-actions">
          <button class="action-btn" wx:if="{{item.status === 'PENDING'}}" bindtap="payOrder" data-id="{{item.id}}" data-event-bubbles="false">去支付</button>
          <button class="action-btn" wx:if="{{item.status === 'PAID'}}" bindtap="confirmOrder" data-id="{{item.id}}" data-event-bubbles="false">确认完成</button>
          <button class="action-btn secondary" wx:if="{{item.status === 'COMPLETED'}}" bindtap="writeReview" data-id="{{item.id}}" data-event-bubbles="false">去评价</button>
          <button class="action-btn secondary" wx:if="{{item.status === 'PENDING'}}" bindtap="cancelOrder" data-id="{{item.id}}" data-event-bubbles="false">取消订单</button>
        </view>
      </view>
    </view>
    
    <view class="empty-tip" wx:if="{{orders.length === 0}}">
      <text>暂无订单</text>
    </view>
  </view>
</view>
