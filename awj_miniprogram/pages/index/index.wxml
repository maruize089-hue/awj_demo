<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品或服务" bindinput="onSearchInput" bindconfirm="onSearch" />
    <text class="search-icon">🔍</text>
  </view>
  
  <scroll-view class="banner-scroll" scroll-x enable-flex>
    <view class="banner-list">
      <view class="banner-item" wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
        <text class="banner-title">{{item.title}}</text>
      </view>
    </view>
  </scroll-view>
  
  <view class="category-section">
    <text class="section-title">分类</text>
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
          <view class="category-icon">{{getCategoryIcon(item.name)}}</view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
  
  <view class="product-section">
    <view class="section-header">
      <text class="section-title">热门商品</text>
      <text class="section-more" bindtap="goToCategory">更多 ›</text>
    </view>
    <view class="product-list">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="PRODUCT">
        <image class="product-image" src="{{item.image}}" mode="aspectFill" />
        <text class="product-name ellipsis-2">{{item.name}}</text>
        <text class="product-price">{{item.price}}</text>
        <text class="product-sales">销量 {{item.sales}}</text>
      </view>
    </view>
  </view>
  
  <view class="service-section">
    <view class="section-header">
      <text class="section-title">热门服务</text>
      <text class="section-more" bindtap="goToCategory">更多 ›</text>
    </view>
    <view class="service-list">
      <view class="service-card" wx:for="{{services}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}" data-type="SERVICE">
        <image class="service-image" src="{{item.image}}" mode="aspectFill" />
        <text class="service-name ellipsis-2">{{item.name}}</text>
        <text class="service-price">{{item.price}}</text>
        <text class="service-duration">{{item.duration}}分钟</text>
      </view>
    </view>
  </view>
</view>
