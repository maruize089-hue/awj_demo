.search-bar {
  position: relative;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 15rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  width: 90%;
  height: 60rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.banner-scroll {
  margin-bottom: 20rpx;
}

.banner-list {
  display: flex;
  padding: 10rpx 0;
}

.banner-item {
  width: 560rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 280rpx;
}

.banner-title {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.category-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666666;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #ff6b35;
}

.product-list, .service-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card, .service-card {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.product-image, .service-image {
  width: 100%;
  height: 280rpx;
}

.product-name, .service-name {
  padding: 15rpx;
  font-size: 28rpx;
  color: #333333;
}

.product-price, .service-price {
  padding: 0 15rpx;
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: 600;
}

.product-price::before, .service-price::before {
  content: '¥';
  font-size: 24rpx;
}

.product-sales, .service-duration {
  padding: 10rpx 15rpx 15rpx;
  font-size: 24rpx;
  color: #999999;
}
