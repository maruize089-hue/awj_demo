.cart-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.cart-list {
  padding-bottom: 120rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 20rpx;
  margin-bottom: 10rpx;
}

.checkbox {
  width: 50rpx;
  height: 50rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.checkbox-icon {
  font-size: 24rpx;
  color: transparent;
}

.checkbox-icon.checked {
  color: #ff6b35;
}

.checkbox.checked {
  border-color: #ff6b35;
  background: #ff6b35;
}

.cart-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.cart-info {
  flex: 1;
}

.cart-name {
  font-size: 28rpx;
  color: #333333;
}

.cart-spec {
  font-size: 24rpx;
  color: #999999;
  margin: 10rpx 0;
  display: block;
}

.cart-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.cart-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: 600;
}

.cart-price::before {
  content: '¥';
  font-size: 24rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666666;
}

.qty-num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 10rpx;
}

.empty-cart {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 40rpx;
}

.go-shopping-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.footer-left {
  display: flex;
  align-items: center;
}

.footer-left .checkbox {
  margin-right: 15rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: #333333;
}

.footer-right {
  display: flex;
  align-items: center;
}

.total-price {
  margin-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-value {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: 600;
}

.total-value::before {
  content: '¥';
  font-size: 26rpx;
}

.submit-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}
