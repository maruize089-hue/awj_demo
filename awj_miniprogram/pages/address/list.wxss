.address-list-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.address-list {
  padding: 20rpx;
}

.address-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.address-user {
  display: flex;
  align-items: center;
}

.address-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666666;
}

.default-tag {
  padding: 5rpx 15rpx;
  background: #ff6b35;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #666666;
  display: block;
}

.address-actions {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  display: flex;
}

.action-edit {
  font-size: 26rpx;
  color: #666666;
  margin-right: 20rpx;
}

.action-delete {
  font-size: 26rpx;
  color: #ff4444;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

.add-btn {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}
