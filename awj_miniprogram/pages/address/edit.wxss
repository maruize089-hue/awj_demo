.address-edit-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.form-item {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 30rpx;
  color: #333333;
}

.region-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
}

.region-picker text:first-child {
  font-size: 30rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 30rpx;
  color: #333333;
}

.default-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333333;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}
